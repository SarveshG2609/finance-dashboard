# ── Backend ───────────────────────────────────────────────────────────────────
# Postgres connection string (Railway injects this automatically).
# Leave unset to use local SQLite (data/finance.sqlite3) for development.
DATABASE_URL=postgresql://user:password@host:5432/dbname

# Comma-separated list of allowed frontend origins for CORS.
# Set to your Railway frontend URL in production.
# Defaults to * (allow all) if unset — fine for local dev, not for production.
ALLOWED_ORIGINS=https://your-frontend.railway.app

# ── Frontend (Vite) ───────────────────────────────────────────────────────────
# Set to your Railway backend URL so the frontend knows where to send API calls.
# Leave unset in local dev — the Vite proxy handles it.
VITE_API_URL=https://your-backend.railway.app
